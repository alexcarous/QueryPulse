# Core (Required)
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Scheduling / Frequency (Optional)
# This changes the title of your notifications (e.g. "Weekly Updates")
# Options: second, minute, hourly, daily, weekly, annually
FREQUENCY=weekly

# Notification Channels (At least one is required)
NTFY_TOPIC=your_secret_ntfy_topic_name
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Robustness Tools (Optional)
HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# Model Overrides (Optional)
# GROQ_MODEL=llama-3.3-70b-versatile
