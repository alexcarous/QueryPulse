# Core (Required)
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Scheduling / Frequency (Optional)
# This changes the title of your notifications (e.g. "Weekly Updates")
# Options: second, minute, hourly, daily, weekly, annually
FREQUENCY=weekly

# Notification Channels (At least one is required)
NTFY_TOPIC=your_secret_ntfy_topic_name
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Robustness Tools (Optional)
GROQ_API_KEY=your_groq_api_key_here
HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# Google Sheets Configuration (Optional)
# If these are set, the script will read from the cloud spreadsheet instead of prompts.txt
# GOOGLE_CREDENTIALS_FILE=/path/to/your/google_service_account.json
# GOOGLE_SHEET_NAME=prompts

# Model Overrides (Optional)
# GEMINI_MODEL=gemini-flash-latest
# GROQ_MODEL=groq-flash-latest
